# ============================================================================
# TorrentTrader — Stack Environment Variables
#
# Copy this file and fill in the REQUIRED values before deploying.
# In Portainer: paste these into the stack's "Environment variables" section.
# ============================================================================

# --- REQUIRED (no defaults, stack will fail without these) ---

# Database password for PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-generate-a-random-secret

# MinIO root password (min 8 characters)
# The backend S3 credentials are derived from this automatically.
MINIO_ROOT_PASSWORD=change-me-minio-password

# --- OPTIONAL (sensible defaults provided) ---

# Image tag — set to a version like "0.1.0" for pinned deploys
# IMAGE_TAG=latest

# --- Ports ---
# BACKEND_PORT=8080
# FRONTEND_PORT=3000

# --- Site ---
# SITE_NAME=TorrentTrader
# SITE_DESCRIPTION=Private BitTorrent Tracker
# SITE_BASE_URL=http://localhost:3000
# API_URL=http://localhost:8080

# --- Database ---
# POSTGRES_DB=torrenttrader
# POSTGRES_USER=torrenttrader
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=5m

# --- Sessions ---
# SESSION_STORE=redis
# ACCESS_TOKEN_TTL=1h
# REFRESH_TOKEN_TTL=720h

# --- Storage ---
# STORAGE_TYPE=s3
# MINIO_ROOT_USER=minioadmin
# S3_BUCKET=torrenttrader

# --- SMTP ---
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_FROM=noreply@torrenttrader.local

# --- Tracker ---
# TRACKER_ANNOUNCE_INTERVAL=1800
# TRACKER_MIN_INTERVAL=900
# TRACKER_MAX_PEERS=50

# --- Worker ---
# ENABLE_SCHEDULER=true

# --- Logging ---
# LOG_LEVEL=info
