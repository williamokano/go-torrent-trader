# DEV ONLY — For production, use 1Password secret references (op://) instead of literal values.

# Database
DATABASE_URL=postgres://torrenttrader:password@localhost:5432/torrenttrader?sslmode=disable
POSTGRES_PORT=5432
POSTGRES_DB=torrenttrader
POSTGRES_USER=torrenttrader
POSTGRES_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# JWT
JWT_SECRET=change-me-in-production

# MinIO / S3
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=torrenttrader
S3_USE_SSL=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=torrenttrader

# Mail
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@torrenttrader.local
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Frontend
VITE_API_URL=http://localhost:8080/api

# Migration Tool (source database - legacy TorrentTrader MySQL)
MIGRATION_SOURCE_DSN=mysql://root:password@localhost:3306/torrenttrader_legacy
MIGRATION_TARGET_DSN=postgres://torrenttrader:password@localhost:5432/torrenttrader?sslmode=disable
